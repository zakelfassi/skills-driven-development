{
  "ignorePatterns": [
    { "pattern": "^https?://localhost" },
    { "pattern": "^#" }
  ],
  "httpHeaders": [
    {
      "urls": ["https://docs.github.com/"],
      "headers": { "User-Agent": "skdd-link-check" }
    }
  ],
  "timeout": "20s",
  "retryOn429": true,
  "retryCount": 3,
  "aliveStatusCodes": [200, 206, 301, 302, 307, 308, 403, 418]
}
