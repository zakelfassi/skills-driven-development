---
/**
 * TerminalCast.astro — macOS-style terminal animation of real skdd CLI output.
 *
 * Data source: src/data/skdd-cast.json (generated by site/scripts/record-cast.mjs).
 * Zero client frameworks; one tiny vanilla <script> drives the loop.
 * prefers-reduced-motion: shows the full transcript statically.
 */
import castDataRaw from '../data/skdd-cast.json';

interface CastItem {
  type: 'cmd' | 'out';
  text: string;
  delayMs: number;
}
interface CastData {
  totalMs: number;
  items: CastItem[];
}

const { totalMs, items } = castDataRaw as CastData;

const CHAR_MS = 55; // ms per character for typewriter speed

function getAnim(item: CastItem): string {
  if (item.type === 'cmd') {
    const n = item.text.length;
    const dur = n * CHAR_MS;
    return `skdd-type ${dur}ms steps(${n}) ${item.delayMs}ms 1 forwards`;
  }
  return `skdd-fade 150ms ease ${item.delayMs}ms 1 forwards`;
}
---

<figure class="tc-figure">
  <div class="tc-cast" id="tc-cast-main" aria-hidden="true">
    <!-- macOS terminal chrome -->
    <div class="tc-bar">
      <span class="tc-dot tc-dot-r"></span>
      <span class="tc-dot tc-dot-y"></span>
      <span class="tc-dot tc-dot-g"></span>
      <span class="tc-bar-title">skdd — init → forge → doctor</span>
    </div>
    <!-- Terminal body: each CLI line is one <span> -->
    <div class="tc-body">
      {/* ESCAPING CONTRACT: item.text must be HTML-safe.
           record-cast.mjs escapes & < > BEFORE applying SGR→span decoration,
           so set:html only ever receives escaped text + generator's own tags. */}
      {items.map((item) => (
        <span
          class={`tc-line tc-${item.type}`}
          style={`--anim:${getAnim(item)}`}
          set:html={item.text}
        />
      ))}
    </div>
  </div>
  <figcaption class="tc-caption">
    Real output from <code>skdd</code> — recorded, not mocked.
  </figcaption>
</figure>

<!--
  is:global needed so:
  - @keyframes names are not mangled (Astro does scope keyframes in scoped styles)
  - SGR classes (.tc-green etc.) injected via set:html can be styled
  All selectors are namespaced under .tc-cast / .tc-figure to avoid leaks.
-->
<style is:global>
  /* ── Layout ───────────────────────────────────────────────── */
  .tc-figure {
    margin: 2.5rem auto;
    max-width: 700px;
  }

  /* ── Terminal window ──────────────────────────────────────── */
  .tc-cast {
    font-family: 'SF Mono', 'Menlo', 'Monaco', 'Cascadia Code', 'Consolas',
      'Liberation Mono', monospace;
    font-size: 0.775rem;
    line-height: 1.65;
    border-radius: 10px;
    overflow: hidden;
    background: #1a1b26;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.07),
      0 20px 60px rgba(0, 0, 0, 0.5);
  }

  /* ── Title bar ────────────────────────────────────────────── */
  .tc-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    background: #24253a;
    padding: 9px 14px;
    user-select: none;
  }

  .tc-dot {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .tc-dot-r { background: #ff5f57; }
  .tc-dot-y { background: #febc2e; }
  .tc-dot-g { background: #28c840; }

  .tc-bar-title {
    flex: 1;
    text-align: center;
    font-size: 0.68rem;
    color: #4a4b5e;
    margin-right: 39px; /* visual compensation for 3 dots on left */
  }

  /* ── Body ─────────────────────────────────────────────────── */
  .tc-body {
    padding: 14px 20px 22px;
  }

  /* ── Line defaults (hidden until .running parent) ─────────── */
  .tc-cast .tc-line {
    display: block;
    opacity: 0;
    color: #c0caf5;
  }

  .tc-cast .tc-cmd {
    color: #9ece6a;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  /* ── Animations — active only when .running ───────────────── */
  .tc-cast.running .tc-line {
    animation: var(--anim);
  }

  @keyframes skdd-type {
    from { width: 0; opacity: 1 }
    to   { width: 100%; opacity: 1 }
  }

  @keyframes skdd-fade {
    from { opacity: 0; transform: translateY(3px) }
    to   { opacity: 1; transform: translateY(0) }
  }

  /* ── SGR colors (set:html injects these class names) ─────── */
  .tc-cast .tc-green  { color: #9ece6a; }
  .tc-cast .tc-yellow { color: #e0af68; }
  .tc-cast .tc-dim    { color: #4a4b5e; }
  .tc-cast b          { color: #bb9af7; font-weight: 600; }

  /* ── Caption ─────────────────────────────────────────────── */
  .tc-caption {
    text-align: center;
    font-size: 0.75rem;
    color: #6e6e8a;
    margin-top: 0.6rem;
    font-style: italic;
  }
  .tc-caption code {
    font-family: inherit;
    background: none;
    border: none;
    padding: 0;
    font-style: normal;
    color: inherit;
  }

  /* ── Reduced motion: show full transcript statically ─────── */
  @media (prefers-reduced-motion: reduce) {
    .tc-cast .tc-line {
      opacity: 1 !important;
      animation: none !important;
    }
    .tc-cast .tc-cmd {
      width: auto !important;
      overflow: visible !important;
    }
  }
</style>

<script define:vars={{ totalMs }}>
  /**
   * Drives the terminal animation loop.
   * 1. Adds .running to kick off all CSS animations simultaneously.
   * 2. After totalMs the cast resets (removes .running) and replays after a pause.
   * Forces a reflow between remove and add so browsers restart animations.
   */
  (function () {
    const cast = document.getElementById('tc-cast-main');
    if (!cast) return;

    const LOOP_PAUSE_MS = 1800;

    function play() {
      cast.classList.remove('running');
      // Force reflow so removing + re-adding the class restarts animations
      void cast.getBoundingClientRect();
      cast.classList.add('running');

      setTimeout(function () {
        cast.classList.remove('running');
        setTimeout(play, LOOP_PAUSE_MS);
      }, totalMs);
    }

    play();
  })();
</script>
